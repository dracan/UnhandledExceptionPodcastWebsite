{%- set isHome = (page.url == "/") -%}
{%- if isHome -%}
  {%- set pageTitle = site.title -%}
{%- elif title -%}
  {%- set pageTitle = title + " // " + site.title -%}
{%- else -%}
  {%- set pageTitle = site.title -%}
{%- endif -%}
{%- set pageDescription = description or site.description -%}
{%- set canonicalUrl = (site.baseUrl | replace(r/\/$/, "")) + page.url -%}
{%- set ogImage = (images and images[0]) or "/images/DanTwitterCard.jpg" -%}
{%- set ogImageAbs = (site.baseUrl | replace(r/\/$/, "")) + (ogImage if ogImage.startsWith("/") else "/" + ogImage) -%}
<!doctype html>
<html lang="{{ site.languageCode }}">
<head>
  <title>{{ pageTitle }}</title>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://www.buzzsprout.com">
  <link rel="preconnect" href="https://giscus.app">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <meta name="author" content="{{ site.author }}" />
  <meta name="description" content="{{ pageDescription }}" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.buzzsproutRssUrl }}" />

  <!-- OpenGraph -->
  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:type" content="{{ 'website' if isHome else 'article' }}" />
  <meta property="og:url" content="{{ canonicalUrl }}" />
  <meta property="og:description" content="{{ pageDescription }}" />
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta property="og:image" content="{{ ogImageAbs }}" />

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="{{ 'summary_large_image' if (twitter_cards and images and images.length > 0) else 'summary' }}" />
  <meta name="twitter:title" content="{{ pageTitle }}" />
  <meta name="twitter:description" content="{{ pageDescription }}" />
  <meta name="twitter:site" content="@dracan" />
  <meta name="twitter:image" content="{{ ogImageAbs }}" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.googleAnalyticsId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.googleAnalyticsId }}');
  </script>
</head>
