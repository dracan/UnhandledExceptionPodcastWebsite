---
layout: layouts/base.njk
---
{% from "partials/icon.njk" import icon with context %}
<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      <div>
        {{ icon("calendar") }}
        {{ page.date | dateDisplay }}
      </div>
      {%- if tags and tags.length > 0 %}
      <div>
        {{ icon("tag") }}
        {%- for t in tags %}
        <a class="tag" href="{{ t | tagUrl }}">{{ t | humanize }}</a>
        {%- endfor %}
      </div>
      {%- endif %}
    </div>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
  <div class="post-footer">
    {% include "partials/giscus.njk" %}
  </div>
</article>
